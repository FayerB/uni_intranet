# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# ─── Base de datos ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=intranet_uni
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_secreta_de_al_menos_64_chars
JWT_EXPIRES_IN=8h

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ─── Archivos ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─── AWS S3 (opcional — si S3_ACTIVO=true en configuracion_sistema) ───────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# ─── Email ────────────────────────────────────────────────────────────────────
# Activar con: UPDATE configuracion_sistema SET valor='true' WHERE clave='notif_email_activo'
NOTIF_EMAIL_ACTIVO=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NOMBRE_INSTITUCION=Mi Universidad

# ─── Zoom (opcional) ──────────────────────────────────────────────────────────
ZOOM_API_KEY=
ZOOM_API_SECRET=
